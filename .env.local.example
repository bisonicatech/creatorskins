# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Dashboard > Developers > API keys)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Dashboard > Developers > Webhooks > your endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=
# v2 Event Destination signing secret — separate from the v1 secret above,
# see README for how to create the Event Destination itself
STRIPE_WEBHOOK_SECRET_V2=

# Resend (resend.com/api-keys)
RESEND_API_KEY=
EMAIL_FROM=payouts@creatorskins.com

# Platform economics
PLATFORM_COMMISSION_BPS=1750

NEXT_PUBLIC_APP_URL=http://localhost:3000
